<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <TextureView
        android:id="@+id/previewTexture"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:color/black" />

    <TextView
        android:id="@+id/textSignal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="top|start"
        android:layout_margin="16dp"
        android:background="#88000000"
        android:paddingHorizontal="10dp"
        android:paddingVertical="6dp"
        android:textColor="@android:color/white"
        android:textSize="14sp"
        android:text="@string/signal_unknown" />

    <LinearLayout
        android:id="@+id/controlsPanel"
        android:layout_width="280dp"
        android:layout_height="match_parent"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:background="#AA000000"
        android:padding="16dp">

        <EditText
            android:id="@+id/editPcIp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="@string/label_pc_ip"
            android:inputType="text"
            android:textColor="@android:color/white"
            android:textColorHint="#CCCCCC"
            android:autofillHints="" />

        <EditText
            android:id="@+id/editPcPort"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="@string/label_pc_port"
            android:inputType="number"
            android:textColor="@android:color/white"
            android:textColorHint="#CCCCCC"
            android:text="5600" />

        <Spinner
            android:id="@+id/spinnerResolution"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:entries="@array/resolution_labels" />

        <Spinner
            android:id="@+id/spinnerFps"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:entries="@array/fps_labels" />

        <Button
            android:id="@+id/buttonStartStop"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/button_start" />

        <TextView
            android:id="@+id/textStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:textColor="@android:color/white"
            android:text="@string/status_idle" />

    </LinearLayout>

</FrameLayout>
